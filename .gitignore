node_modules/
# This starter tracks the latest published Astur (package.json uses `latest`).
# A committed lockfile would pin an old version and defeat that — let npm resolve
# `latest` fresh on every install.
package-lock.json
test-results/
playwright-report/
.playwright-cli/
*.tsbuildinfo
.DS_Store

# Demo app: the Android APK and zipped iOS simulator build are committed so the
# suite is clone-and-run. The unpacked .app and the real-device .ipa stay out.
assets/Astur.app/
assets/*.ipa
