{
  "name": "astur-boilerplate",
  "private": true,
  "type": "module",
  "description": "Starter Astur mobile test suites (Android + iOS) using @astur/test and the astur-mobile CLI.",
  "scripts": {
    "help": "node -e \"console.log(['Available commands:', '  npm run doctor', '  npm run devices', '  npm run devices:android', '  npm run devices:ios', '  npm run test:android', '  npm run test:ios', '  npm run test:ios:real', '  npm run test:parallel', '  npm run test:android:spec -- android-native/login.test.ts', '  npm run test:ios:spec -- android-native/login.test.ts', '  npm run test:parallel:spec -- android-native/login.test.ts', '  npm run codegen:android:emulator', '  npm run codegen:ios:simulator'].join('\\n'))\"",
    "doctor": "npx astur-mobile doctor",
    "devices": "npx astur-mobile devices",
    "devices:android": "npx astur-mobile devices --android",
    "devices:ios": "npx astur-mobile devices --ios",
    "test:android": "npx astur-mobile test --config ./android-native/playwright.config.ts",
    "test:android:spec": "npx astur-mobile test --config ./android-native/playwright.config.ts",
    "test:ios": "npx astur-mobile test --config ./ios-native/playwright.config.ts",
    "test:ios:spec": "npx astur-mobile test --config ./ios-native/playwright.config.ts",
    "test:ios:real": "ASTUR_IOS_DEVICE_KIND=real npx astur-mobile test --config ./ios-native/playwright.config.ts",
    "test:ios:simulator": "ASTUR_IOS_DEVICE_KIND=simulator npx astur-mobile test --config ./ios-native/playwright.config.ts",
    "test:parallel": "npx astur-mobile test --config ./android-native/playwright.parallel.config.ts",
    "test:parallel:spec": "npx astur-mobile test --config ./android-native/playwright.parallel.config.ts",
    "codegen:android:emulator": "npx astur-mobile codegen --android --device emulator-5554 --app ./assets/astur.demo.android.apk --app-id com.astur.demo",
    "codegen:ios:simulator": "npx astur-mobile codegen --ios --simulator --app ./assets/Astur.app --app-id com.astur.demo",
    "codegen:ios:real": "npx astur-mobile codegen --ios --real --device 00008030-000548220EF0802E --app ./assets/astur.demo.ios.ipa --app-id com.astur.demo"
  },
  "devDependencies": {
    "@astur/test": "latest",
    "astur-mobile": "latest",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
